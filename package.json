{
  "name": "nuxt-app",
  "private": true,
  "scripts": {
    "start": "nuxt dev",
    "build": "nuxt build",
    "build-fix-poper-not-found-bug": "nuxi build && mkdir .output/server/node_modules/@popperjs && mv .output/server/node_modules/@sxzz/popperjs-es .output/server/node_modules/@popperjs/core",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "postinstall": "nuxt prepare",
    "prepare": "husky install",
    "lint:eslint": "eslint --cache --max-warnings 10 \"src/**/*.{vue,js}\" --fix",
    "lint": "pnpm lint:eslint"
  },
  "dependencies": {
    "@element-plus/nuxt": "^1.1.3",
    "@pinia/nuxt": "^0.4.11",
    "element-plus": "^2.5.6",
    "lodash-es": "^4.17.21",
    "pinia": "^2.1.3",
    "sass": "^1.62.1",
    "swiper": "^11.0.6",
    "vue-i18n": "^9.9.1"
  },
  "devDependencies": {
    "@commitlint/cli": "^8.3.5",
    "@commitlint/config-conventional": "^8.3.4",
    "@element-plus/icons-vue": "^2.1.0",
    "@types/node": "^18",
    "@vueuse/core": "^13.3.0",
    "@vueuse/nuxt": "^13.3.0",
    "axios": "^1.4.0",
    "date-fns": "^2.30.0",
    "eslint": "^7.32.0",
    "eslint-plugin-vue": "^8.0.0",
    "husky": "^8.0.3",
    "less": "^4.1.3",
    "less-loader": "^11.1.0",
    "nuxt": "^3.15.1",
    "postcss-px-to-viewport": "^1.1.1"
  },
  "husky": {
    "hooks": {
      "pre-commit": "lint-staged",
      "commit-msg": "commitlint -e $HUSKY_GIT_PARAMS"
    }
  },
  "lint-staged": {
    "*.{js,jsx,vue,ts,tsx}": [
      "eslint --fix"
    ]
  }
}